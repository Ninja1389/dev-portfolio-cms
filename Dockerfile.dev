FROM node:22-alpine

WORKDIR /app

# Installa dipendenze prima di copiare tutto
# così il layer viene cachato se package.json non cambia
COPY package*.json ./
RUN npm install

COPY . .

EXPOSE 3000

# Esegue le migrazioni Prisma e poi avvia Next.js in dev mode
CMD ["sh", "-c", "npx prisma migrate deploy && npm run dev"]